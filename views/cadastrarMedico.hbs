<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastrar Médico</title>

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body{
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        .containerPrincipal{
            width: 100%;
            max-width: 700px;
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .tituloPagina{
            text-align: center;
            color: #0f172a;
            font-size: 2rem;
            margin-bottom: 30px;
        }

        .formulario{
            display: flex;
            flex-direction: column;
            gap: 22px;
        }

        .grupoCampo{
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .labelCampo{
            font-weight: bold;
            color: #334155;
        }

        .inputCampo,
        .selectCampo{
            padding: 14px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            font-size: 1rem;
            transition: 0.3s;
        }

        .inputCampo:focus,
        .selectCampo:focus{
            outline: none;
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.15);
        }

        .selectCampo{
            min-height: 180px;
        }

        .textoAjuda{
            font-size: 0.9rem;
            color: #64748b;
        }

        .grupoBotoes{
            display: flex;
            gap: 12px;
            margin-top: 10px;
        }

        .botao{
            flex: 1;
            border: none;
            padding: 14px;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .botaoPrimario{
            background: #2563eb;
            color: white;
        }

        .botaoPrimario:hover{
            background: #1d4ed8;
        }

        .botaoSecundario{
            background: #e2e8f0;
            color: #0f172a;
            text-decoration: none;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .botaoSecundario:hover{
            background: #cbd5e1;
        }

        @media (max-width: 600px){

            .containerPrincipal{
                padding: 25px;
            }

            .grupoBotoes{
                flex-direction: column;
            }
        }

    </style>
</head>

<body>

    <div class="containerPrincipal">

        <h1 class="tituloPagina">
            Cadastrar Médico
        </h1>

        <form action="/medico" method="POST" class="formulario">

            <div class="grupoCampo">

                <label for="nome" class="labelCampo">
                    Nome
                </label>

                <input
                    type="text"
                    id="nome"
                    name="nome"
                    required
                    class="inputCampo"
                    placeholder="Digite o nome do médico"
                >

            </div>

            <div class="grupoCampo">

                <label for="especialidades" class="labelCampo">
                    Especialidades
                </label>

                <select
                    id="especialidades"
                    name="especialidades"
                    multiple
                    required
                    class="selectCampo"
                >

                    {{#each especialidades}}

                        <option value="{{this.id}}">
                            {{this.descricao}}
                        </option>

                    {{/each}}

                </select>

                <div class="textoAjuda">
                    Segure CTRL (Windows/Linux) ou CMD (Mac) para selecionar múltiplas especialidades.
                </div>

            </div>

            <div class="grupoBotoes">

                <button type="submit" class="botao botaoPrimario">
                    Cadastrar
                </button>

                <a href="/medico" class="botao botaoSecundario">
                    Cancelar
                </a>

            </div>

        </form>

    </div>

</body>
</html>