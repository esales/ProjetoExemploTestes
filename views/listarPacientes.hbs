<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Listar Pacientes</title>

    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body{
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a, #1e293b);
            padding: 40px;
            color: #0f172a;
        }

        .containerPrincipal{
            max-width: 900px;
            margin: auto;
            background: white;
            padding: 35px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .topoPagina{
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 30px;
        }

        .tituloPagina{
            font-size: 2rem;
        }

        .grupoBotoes{
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .botaoLink{
            text-decoration: none;
            background: #2563eb;
            color: white;
            padding: 12px 18px;
            border-radius: 10px;
            font-weight: bold;
            transition: 0.3s;
        }

        .botaoLink:hover{
            background: #1d4ed8;
        }

        .botaoSecundario{
            background: #e2e8f0;
            color: #0f172a;
        }

        .botaoSecundario:hover{
            background: #cbd5e1;
        }

        .listaPacientes{
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .itemPaciente{
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 18px;
            transition: 0.3s;
        }

        .itemPaciente:hover{
            transform: translateY(-3px);
            box-shadow: 0 6px 18px rgba(0,0,0,0.1);
        }

        .nomePaciente{
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 6px;
        }

        .descricaoProntuario{
            color: #475569;
        }

        @media (max-width: 600px){

            body{
                padding: 20px;
            }

            .containerPrincipal{
                padding: 25px;
            }

            .topoPagina{
                flex-direction: column;
                align-items: stretch;
            }

            .grupoBotoes{
                flex-direction: column;
            }

            .botaoLink{
                text-align: center;
            }
        }
    </style>
</head>

<body>

    <div class="containerPrincipal">

        <div class="topoPagina">

            <h1 class="tituloPagina">
                Lista de Pacientes
            </h1>

            <div class="grupoBotoes">

                <a href="/paciente/novo" class="botaoLink">
                    Cadastrar Paciente
                </a>

                <a href="/" class="botaoLink botaoSecundario">
                    Voltar
                </a>

            </div>

        </div>

        <ul class="listaPacientes">

            {{#each pacientes}}

                <li class="itemPaciente">

                    <div class="nomePaciente">
                        {{this.nome}}
                    </div>

                    <div class="descricaoProntuario">
                        {{this.prontuario.descricao}}
                    </div>

                </li>

            {{/each}}

        </ul>

    </div>

</body>
</html>