<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sistema Hospitalar</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #0f172a, #1e293b);
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 30px;
    }

    .containerPrincipal {
      width: 100%;
      max-width: 700px;
      background: white;
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .tituloPrincipal {
      text-align: center;
      margin-bottom: 35px;
      color: #0f172a;
      font-size: 2.2rem;
    }

    .gradeCards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

    .card {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      padding: 20px;
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }

    .tituloCard {
      color: #0f172a;
      margin-bottom: 15px;
      font-size: 1.3rem;
    }

    .grupoLinks {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .botaoLink {
      text-decoration: none;
      background: #2563eb;
      color: white;
      padding: 12px;
      border-radius: 10px;
      text-align: center;
      font-weight: bold;
      transition: 0.3s;
    }

    .botaoLink:hover {
      background: #1d4ed8;
    }

    .botaoSecundario {
      background: #e2e8f0;
      color: #0f172a;
    }

    .botaoSecundario:hover {
      background: #cbd5e1;
    }

    @media (max-width: 600px) {
      .containerPrincipal {
        padding: 25px;
      }

      .tituloPrincipal {
        font-size: 1.8rem;
      }
    }
  </style>
</head>

<body>

  <div class="containerPrincipal">

    <h1 class="tituloPrincipal">
        Sistema Hospitalar
    </h1>

    <div class="gradeCards">

      <div class="card">

        <h2 class="tituloCard">
          Médicos
        </h2>

        <div class="grupoLinks">
          <a href="/medico" class="botaoLink">
            Visualizar Médicos
          </a>

          <a href="/medico/novo" class="botaoLink botaoSecundario">
            Cadastrar Médico
          </a>
        </div>

      </div>

      <div class="card">

        <h2 class="tituloCard">
          Especialidades
        </h2>

        <div class="grupoLinks">
          <a href="/especialidade" class="botaoLink">
            Visualizar Especialidades
          </a>

          <a href="/especialidade/novo" class="botaoLink botaoSecundario">
            Cadastrar Especialidade
          </a>
        </div>

      </div>

      <div class="card">

        <h2 class="tituloCard">
          Pacientes
        </h2>

        <div class="grupoLinks">
          <a href="/paciente" class="botaoLink">
            Visualizar Pacientes
          </a>

          <a href="/paciente/novo" class="botaoLink botaoSecundario">
            Cadastrar Paciente
          </a>
        </div>

      </div>

      <div class="card">

        <h2 class="tituloCard">
          Consultas
        </h2>

        <div class="grupoLinks">
          <a href="/consulta" class="botaoLink">
            Visualizar Consultas
          </a>

          <a href="/consulta/novo" class="botaoLink botaoSecundario">
            Cadastrar Consulta
          </a>
        </div>

      </div>

    </div>

  </div>

</body>
</html>